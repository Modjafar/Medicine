# === MEDITRACK ENVIRONMENT VARIABLES ===
# Copy this file to .env and fill in your actual values

# ============ DATABASE ============
MONGODB_URI=mongodb://localhost:27017/meditrack
# OR for MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/meditrack?retryWrites=true&w=majority

# ============ SERVER ============
PORT=5000
NODE_ENV=development
# For production, change to: NODE_ENV=production

# ============ FRONTEND URL ============
FRONTEND_URL=http://localhost:3000
# For production: FRONTEND_URL=https://yourdomain.com

# ============ JWT (Authentication) ============
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ============ EMAIL CONFIGURATION (Nodemailer + Gmail) ============
# IMPORTANT: Follow setup instructions below!

# Gmail SMTP Credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Alternative Email Service (Optional, not set up yet)
# EMAIL_SERVICE=gmail|sendgrid|mailgun|etc
# EMAIL_FROM_NAME=MediTrack

# ============ LOGGING ============
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============ OPTIONAL: TWILIO (For SMS Alerts) ============
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_token
# TWILIO_PHONE_NUMBER=+1234567890

# ============ OPTIONAL: AWS S3 (For File Storage) ============
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=meditrack-bucket
# AWS_REGION=us-east-1

# ============ SESSION CONFIGURATION ============
SESSION_SECRET=your_session_secret_key_change_this
COOKIE_MAX_AGE=2592000000

# ============ CORS CONFIGURATION ============
# Set allowed origins for CORS (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============ SECURITY ============
HELMET_ENABLED=true
HTTPS_REDIRECT=false
# For production: HTTPS_REDIRECT=true
